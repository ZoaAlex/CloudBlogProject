{{!-- post.hbs — Single post page --}}
{{!< default}}

<article itemscope itemtype="http://schema.org/BlogPosting">

  {{!-- ============================
       POST HERO
  ============================= --}}
  <header class="post-hero" aria-label="En-tête de l'article">
    {{#if feature_image}}
      <img
        class="post-hero__image"
        src="{{img_url feature_image size="xl"}}"
        srcset="
          {{img_url feature_image size="l"}} 1200w,
          {{img_url feature_image size="xl"}} 2000w
        "
        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
        loading="eager"
        itemprop="image"
      />
    {{/if}}

    <div class="post-hero__overlay" aria-hidden="true"></div>

    <div class="post-hero__content">
      {{#if tags}}
        <div class="post-hero__tags" aria-label="Catégories">
          {{#foreach tags limit="3"}}
            <a href="{{url}}" class="tag-pill">{{name}}</a>
          {{/foreach}}
        </div>
      {{/if}}

      <h1 class="post-hero__title" itemprop="headline">{{title}}</h1>

      {{#if custom_excerpt}}
        <p class="post-hero__excerpt">{{custom_excerpt}}</p>
      {{/if}}

      <div class="post-hero__meta">
        {{#foreach authors}}
          <div class="post-hero__author" itemprop="author" itemscope itemtype="http://schema.org/Person">
            {{#if profile_image}}
              <img
                src="{{img_url profile_image size="xs"}}"
                alt="{{name}}"
                loading="lazy"
              />
            {{/if}}
            <a href="{{url}}" itemprop="name">{{name}}</a>
          </div>
        {{/foreach}}

        <span aria-hidden="true">·</span>

        <time datetime="{{date format="YYYY-MM-DD"}}" itemprop="datePublished">
          {{date format="D MMMM YYYY"}}
        </time>

        {{#if reading_time}}
          <span aria-hidden="true">·</span>
          <span>{{reading_time}} min de lecture</span>
        {{/if}}
      </div>
    </div>
  </header>

  {{!-- ============================
       POST CONTENT
  ============================= --}}
  <div class="post-content" itemprop="articleBody">
    {{content}}
  </div>

  {{!-- Tags footer --}}
  {{#if tags}}
    <div class="post-content" style="padding-top:0;">
      <div style="border-top:1px solid rgba(201,146,42,0.2); padding-top:1.5rem; display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
        <span style="font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; color:rgba(245,234,216,0.4);">Thèmes →</span>
        {{#foreach tags}}
          <a href="{{url}}" class="tag-pill">{{name}}</a>
        {{/foreach}}
      </div>
    </div>
  {{/if}}

  {{!-- ============================
       AUTHOR BOX
  ============================= --}}
  {{#foreach authors}}
    <div class="author-box container" itemscope itemtype="http://schema.org/Person">
      {{#if profile_image}}
        <img
          class="author-box__avatar"
          src="{{img_url profile_image size="s"}}"
          alt="{{name}}"
          loading="lazy"
        />
      {{/if}}
      <div>
        <p class="author-box__name">
          ✍ <a href="{{url}}" itemprop="name">{{name}}</a>
        </p>
        {{#if bio}}
          <p class="author-box__bio">{{bio}}</p>
        {{/if}}
      </div>
    </div>
  {{/foreach}}

  {{!-- ============================
       RELATED POSTS
  ============================= --}}
  {{#get "posts" filter="tags:[{{tags.[0].slug}}]" limit="3" exclude="{{id}}" as |related_posts|}}
    {{#if related_posts}}
      <section class="related-posts" aria-labelledby="related-heading">
        <div class="section-header">
          <p class="section-header__label">Continuer l'aventure</p>
          <h2 class="section-header__title" id="related-heading">Articles similaires</h2>
        </div>
        <div class="post-grid">
          {{#foreach related_posts}}
            {{> "post-card"}}
          {{/foreach}}
        </div>
      </section>
    {{/if}}
  {{/get}}

</article>
