{{!-- tag.hbs — Tag archive page --}}
{{!< default}}

<div class="tags-page">

  {{!-- Tag Header --}}
  <header style="text-align:center; padding-bottom:var(--space-lg);">

    {{#if tag.feature_image}}
      <div style="
        height: 300px;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: var(--space-md);
        position: relative;
        border: 1px solid rgba(201,146,42,0.2);
      ">
        <img
          src="{{img_url tag.feature_image size="l"}}"
          alt="{{tag.name}}"
          style="width:100%; height:100%; object-fit:cover; opacity:0.5;"
          loading="eager"
        />
        <div style="
          position:absolute; inset:0;
          background: linear-gradient(to bottom, transparent 40%, rgba(10,14,26,0.95) 100%);
        "></div>
      </div>
    {{/if}}

    <div class="ornament" aria-hidden="true">
      <span class="ornament-icon">⚓</span>
    </div>

    <p style="
      font-family: var(--font-heading);
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--color-gold);
      margin-bottom: 0.5rem;
    ">Île thématique</p>

    <h1 style="
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 4rem);
      color: var(--color-white);
      margin-bottom: var(--space-sm);
    "># {{tag.name}}</h1>

    {{#if tag.description}}
      <p style="
        font-size: 1.05rem;
        color: var(--color-parchment);
        opacity: 0.75;
        max-width: 600px;
        margin: 0 auto var(--space-sm);
        font-style: italic;
      ">{{tag.description}}</p>
    {{/if}}

    <p style="
      font-family: var(--font-heading);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      color: var(--color-gold);
      opacity: 0.7;
    ">{{pagination.total}} article{{#if pagination.total}}s{{/if}}</p>
  </header>

  {{!-- Posts grid --}}
  <div class="post-grid">
    {{#foreach posts}}
      {{> "post-card"}}
    {{/foreach}}
  </div>

  {{!-- Pagination --}}
  {{#if pagination}}
    <nav class="pagination" role="navigation" aria-label="Pagination">
      {{#if pagination.prev}}
        <a href="{{pagination.prev}}" aria-label="Page précédente">← Précédent</a>
      {{/if}}
      <span class="page-number current" aria-current="page">
        Page {{pagination.page}} / {{pagination.pages}}
      </span>
      {{#if pagination.next}}
        <a href="{{pagination.next}}" aria-label="Page suivante">Suivant →</a>
      {{/if}}
    </nav>
  {{/if}}

</div>
