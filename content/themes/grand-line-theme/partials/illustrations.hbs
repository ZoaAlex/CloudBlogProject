{{!-- partials/illustrations.hbs --}}
{{!-- Reusable SVG illustrations for the Grand Line theme --}}

{{!--
  Usage:
  {{> "illustrations" type="jolly-roger"}}
  {{> "illustrations" type="ship-silhouette"}}
  {{> "illustrations" type="compass"}}
  {{> "illustrations" type="map-ornament"}}
  {{> "illustrations" type="anchor"}}
  {{> "illustrations" type="sea-king"}}
  Available types: jolly-roger, ship-silhouette, compass, map-ornament, anchor, sea-king, waves-hero, wanted-poster-frame
--}}

{{#if (eq type "jolly-roger")}}
{{!-- =====================================================
     JOLLY ROGER — Skull with straw hat
====================================================== --}}
<svg
  class="illustration illustration--jolly-roger"
  width="{{#if width}}{{width}}{{else}}160{{/if}}"
  height="{{#if height}}{{height}}{{else}}160{{/if}}"
  viewBox="0 0 160 160"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Jolly Roger — crâne avec chapeau de paille"
  role="img"
>
  <!-- Straw hat brim -->
  <ellipse cx="80" cy="66" rx="62" ry="11" fill="#c9922a" opacity="0.9"/>
  <!-- Hat crown shadow -->
  <ellipse cx="80" cy="62" rx="36" ry="8" fill="#a07018" opacity="0.6"/>
  <!-- Hat crown -->
  <path d="M44 66 Q44 36 80 34 Q116 36 116 66" fill="#c9922a" opacity="0.95"/>
  <!-- Hat band -->
  <path d="M44 66 Q62 60 80 59 Q98 60 116 66" stroke="#7a4f0a" stroke-width="3" fill="none"/>
  <!-- Hat ribbon knot -->
  <circle cx="80" cy="63" r="4" fill="#7a4f0a"/>

  <!-- Skull -->
  <!-- Cranium -->
  <ellipse cx="80" cy="98" rx="34" ry="30" fill="#f5ead8"/>
  <!-- Skull shade -->
  <ellipse cx="80" cy="102" rx="34" ry="26" fill="#e8d5b0"/>
  <ellipse cx="80" cy="94" rx="34" ry="28" fill="#f5ead8"/>

  <!-- Eye sockets -->
  <ellipse cx="68" cy="94" rx="10" ry="11" fill="#1a1a2e"/>
  <ellipse cx="92" cy="94" rx="10" ry="11" fill="#1a1a2e"/>
  <!-- Eye glints -->
  <circle cx="65" cy="91" r="2.5" fill="rgba(255,255,255,0.15)"/>
  <circle cx="89" cy="91" r="2.5" fill="rgba(255,255,255,0.15)"/>

  <!-- Nose -->
  <path d="M76 108 Q80 104 84 108 Q80 112 76 108Z" fill="#c9b28a"/>

  <!-- Teeth / Jaw -->
  <path d="M62 116 Q80 126 98 116" stroke="#c9b28a" stroke-width="2" fill="none"/>
  <line x1="68" y1="116" x2="67" y2="124" stroke="#c9b28a" stroke-width="2.5" stroke-linecap="round"/>
  <line x1="76" y1="119" x2="76" y2="127" stroke="#c9b28a" stroke-width="2.5" stroke-linecap="round"/>
  <line x1="84" y1="119" x2="84" y2="127" stroke="#c9b28a" stroke-width="2.5" stroke-linecap="round"/>
  <line x1="92" y1="116" x2="93" y2="124" stroke="#c9b28a" stroke-width="2.5" stroke-linecap="round"/>

  <!-- Crossbones -->
  <line x1="28" y1="130" x2="132" y2="78" stroke="#f5ead8" stroke-width="7" stroke-linecap="round" opacity="0.8"/>
  <line x1="28" y1="78" x2="132" y2="130" stroke="#f5ead8" stroke-width="7" stroke-linecap="round" opacity="0.8"/>
  <!-- Bone knobs -->
  <circle cx="26" cy="130" r="6" fill="#e8d5b0"/>
  <circle cx="134" cy="78" r="6" fill="#e8d5b0"/>
  <circle cx="26" cy="78" r="6" fill="#e8d5b0"/>
  <circle cx="134" cy="130" r="6" fill="#e8d5b0"/>
</svg>
{{/if}}

{{#if (eq type "ship-silhouette")}}
{{!-- =====================================================
     THOUSAND SUNNY SHIP SILHOUETTE
====================================================== --}}
<svg
  class="illustration illustration--ship"
  width="{{#if width}}{{width}}{{else}}320{{/if}}"
  height="{{#if height}}{{height}}{{else}}200{{/if}}"
  viewBox="0 0 320 200"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Le Thousand Sunny naviguant sur les flots"
  role="img"
>
  <!-- Ocean waves background -->
  <path d="M0 140 Q40 128 80 140 Q120 152 160 140 Q200 128 240 140 Q280 152 320 140 L320 200 L0 200Z" fill="#1a4a6b" opacity="0.5"/>
  <path d="M0 152 Q40 140 80 152 Q120 164 160 152 Q200 140 240 152 Q280 164 320 152 L320 200 L0 200Z" fill="#112d45" opacity="0.7"/>

  <!-- Hull -->
  <path d="M40 145 Q80 165 160 168 Q240 165 280 145 L270 130 L50 130Z" fill="#c9922a"/>
  <!-- Hull shade -->
  <path d="M40 145 Q80 155 160 158 Q240 155 280 145 L278 148 Q240 162 160 165 Q80 162 42 148Z" fill="#a07018"/>

  <!-- Deck -->
  <rect x="55" y="110" width="210" height="22" rx="4" fill="#8b5e1a"/>
  <!-- Deck planks -->
  <line x1="90" y1="110" x2="90" y2="132" stroke="#7a4f0a" stroke-width="1" opacity="0.5"/>
  <line x1="130" y1="110" x2="130" y2="132" stroke="#7a4f0a" stroke-width="1" opacity="0.5"/>
  <line x1="160" y1="110" x2="160" y2="132" stroke="#7a4f0a" stroke-width="1" opacity="0.5"/>
  <line x1="190" y1="110" x2="190" y2="132" stroke="#7a4f0a" stroke-width="1" opacity="0.5"/>
  <line x1="230" y1="110" x2="230" y2="132" stroke="#7a4f0a" stroke-width="1" opacity="0.5"/>

  <!-- Sunny figurehead (lion face) -->
  <circle cx="52" cy="120" r="16" fill="#f0bc5e"/>
  <!-- Mane -->
  <circle cx="52" cy="120" r="20" fill="#c9922a" opacity="0.6"/>
  <circle cx="52" cy="120" r="16" fill="#f0bc5e"/>
  <!-- Eyes -->
  <circle cx="47" cy="117" r="3" fill="#1a1a2e"/>
  <circle cx="57" cy="117" r="3" fill="#1a1a2e"/>
  <circle cx="47.8" cy="116.2" r="1" fill="white" opacity="0.6"/>
  <circle cx="57.8" cy="116.2" r="1" fill="white" opacity="0.6"/>
  <!-- Nose -->
  <ellipse cx="52" cy="121" rx="3" ry="2" fill="#d4881a"/>
  <!-- Smile -->
  <path d="M47 124 Q52 128 57 124" stroke="#1a1a2e" stroke-width="1.5" fill="none" stroke-linecap="round"/>

  <!-- Main mast -->
  <line x1="160" y1="14" x2="160" y2="112" stroke="#5c3d10" stroke-width="6" stroke-linecap="round"/>
  <!-- Fore mast -->
  <line x1="100" y1="30" x2="100" y2="112" stroke="#5c3d10" stroke-width="5" stroke-linecap="round"/>
  <!-- Mizzen mast -->
  <line x1="224" y1="38" x2="224" y2="112" stroke="#5c3d10" stroke-width="4" stroke-linecap="round"/>

  <!-- Main sail -->
  <path d="M162 16 L200 28 L200 100 L162 112Z" fill="#f5ead8" opacity="0.9"/>
  <path d="M158 16 L120 28 L120 100 L158 112Z" fill="#e8d5b0" opacity="0.85"/>
  <!-- Sail cross -->
  <line x1="120" y1="48" x2="200" y2="48" stroke="#c9922a" stroke-width="2" opacity="0.6"/>
  <line x1="160" y1="16" x2="160" y2="112" stroke="#c9922a" stroke-width="1.5" opacity="0.4"/>

  <!-- Fore sail -->
  <path d="M101 32 L134 40 L134 100 L101 112Z" fill="#f5ead8" opacity="0.8"/>

  <!-- Jolly Roger flag -->
  <line x1="160" y1="14" x2="184" y2="10" stroke="#5c3d10" stroke-width="2"/>
  <path d="M184 10 L210 8 L210 24 L184 26Z" fill="#1a1a2e"/>
  <!-- Mini skull on flag -->
  <circle cx="197" cy="17" r="4" fill="#f5ead8" opacity="0.7"/>
  <line x1="192" y1="22" x2="202" y2="12" stroke="#f5ead8" stroke-width="1.5" opacity="0.6"/>
  <line x1="192" y1="12" x2="202" y2="22" stroke="#f5ead8" stroke-width="1.5" opacity="0.6"/>

  <!-- Rigging lines -->
  <line x1="160" y1="20" x2="100" y2="38" stroke="#5c3d10" stroke-width="1" opacity="0.5"/>
  <line x1="100" y1="38" x2="55" y2="110" stroke="#5c3d10" stroke-width="1" opacity="0.4"/>
  <line x1="160" y1="20" x2="224" y2="42" stroke="#5c3d10" stroke-width="1" opacity="0.5"/>

  <!-- Water reflection -->
  <path d="M60 162 Q160 170 260 162" stroke="#c9922a" stroke-width="1" fill="none" opacity="0.2"/>
</svg>
{{/if}}

{{#if (eq type "compass")}}
{{!-- =====================================================
     LOG POSE / COMPASS
====================================================== --}}
<svg
  class="illustration illustration--compass"
  width="{{#if width}}{{width}}{{else}}120{{/if}}"
  height="{{#if height}}{{height}}{{else}}120{{/if}}"
  viewBox="0 0 120 120"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Log Pose — boussole du Grand Line"
  role="img"
>
  <!-- Outer ring -->
  <circle cx="60" cy="60" r="56" fill="#0d1b2a" stroke="#c9922a" stroke-width="2"/>
  <!-- Inner ring -->
  <circle cx="60" cy="60" r="48" fill="#112d45" stroke="#c9922a" stroke-width="1" opacity="0.6"/>
  <!-- Face -->
  <circle cx="60" cy="60" r="40" fill="#0a0e1a"/>
  <circle cx="60" cy="60" r="38" fill="#0d1b2a"/>

  <!-- Cardinal marks -->
  <text font-family="serif" font-size="11" font-weight="700" fill="#c9922a" text-anchor="middle" dominant-baseline="central" x="60" y="20">N</text>
  <text font-family="serif" font-size="11" font-weight="700" fill="#f5ead8" text-anchor="middle" dominant-baseline="central" x="60" y="102">S</text>
  <text font-family="serif" font-size="11" font-weight="700" fill="#f5ead8" text-anchor="middle" dominant-baseline="central" x="102" y="60">E</text>
  <text font-family="serif" font-size="11" font-weight="700" fill="#f5ead8" text-anchor="middle" dominant-baseline="central" x="18" y="60">O</text>

  <!-- Degree ticks -->
  <g stroke="#c9922a" stroke-width="1" opacity="0.4">
    <line x1="60" y1="24" x2="60" y2="30"/>
    <line x1="60" y1="90" x2="60" y2="96"/>
    <line x1="24"  y1="60" x2="30" y2="60"/>
    <line x1="90"  y1="60" x2="96" y2="60"/>
  </g>
  <g stroke="#c9922a" stroke-width="0.5" opacity="0.25">
    <line x1="79.3" y1="26.7" x2="76.6" y2="31.4"/>
    <line x1="40.7" y1="26.7" x2="43.4" y2="31.4"/>
    <line x1="93.3" y1="40.7" x2="88.6" y2="43.4"/>
    <line x1="93.3" y1="79.3" x2="88.6" y2="76.6"/>
    <line x1="79.3" y1="93.3" x2="76.6" y2="88.6"/>
    <line x1="40.7" y1="93.3" x2="43.4" y2="88.6"/>
    <line x1="26.7" y1="79.3" x2="31.4" y2="76.6"/>
    <line x1="26.7" y1="40.7" x2="31.4" y2="43.4"/>
  </g>

  <!-- Cross hairs -->
  <line x1="60" y1="32" x2="60" y2="88" stroke="#f5ead8" stroke-width="0.5" opacity="0.1"/>
  <line x1="32" y1="60" x2="88" y2="60" stroke="#f5ead8" stroke-width="0.5" opacity="0.1"/>

  <!-- North needle (gold) -->
  <path d="M60 60 L56 40 L60 34 L64 40Z" fill="#c9922a"/>
  <path d="M60 60 L56 40 L60 44Z" fill="#a07018"/>
  <!-- South needle (dark) -->
  <path d="M60 60 L56 80 L60 86 L64 80Z" fill="#1a4a6b"/>
  <path d="M60 60 L56 80 L60 76Z" fill="#112d45"/>

  <!-- Center jewel -->
  <circle cx="60" cy="60" r="5" fill="#c9922a"/>
  <circle cx="60" cy="60" r="3" fill="#f0bc5e"/>
  <circle cx="59" cy="59" r="1" fill="white" opacity="0.5"/>

  <!-- Outer decorative screws -->
  <circle cx="60" cy="7" r="3" fill="#c9922a" opacity="0.7"/>
  <circle cx="60" cy="113" r="3" fill="#c9922a" opacity="0.7"/>
  <circle cx="7" cy="60" r="3" fill="#c9922a" opacity="0.7"/>
  <circle cx="113" cy="60" r="3" fill="#c9922a" opacity="0.7"/>
</svg>
{{/if}}

{{#if (eq type "anchor")}}
{{!-- =====================================================
     ANCHOR ILLUSTRATION
====================================================== --}}
<svg
  class="illustration illustration--anchor"
  width="{{#if width}}{{width}}{{else}}80{{/if}}"
  height="{{#if height}}{{height}}{{else}}100{{/if}}"
  viewBox="0 0 80 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Ancre de marine"
  role="img"
>
  <!-- Anchor ring at top -->
  <circle cx="40" cy="12" r="9" stroke="#c9922a" stroke-width="3" fill="none"/>
  <!-- Crossbar -->
  <line x1="14" y1="26" x2="66" y2="26" stroke="#c9922a" stroke-width="4" stroke-linecap="round"/>
  <!-- Crossbar knobs -->
  <circle cx="14" cy="26" r="4" fill="#c9922a"/>
  <circle cx="66" cy="26" r="4" fill="#c9922a"/>

  <!-- Main shaft -->
  <line x1="40" y1="18" x2="40" y2="86" stroke="#c9922a" stroke-width="4" stroke-linecap="round"/>

  <!-- Stock circle -->
  <circle cx="40" cy="28" r="6" fill="#0d1b2a" stroke="#c9922a" stroke-width="2"/>

  <!-- Flukes -->
  <path d="M40 86 Q22 72 18 60 Q16 50 24 46 Q32 42 34 52 L40 70Z" fill="#c9922a"/>
  <path d="M40 86 Q58 72 62 60 Q64 50 56 46 Q48 42 46 52 L40 70Z" fill="#c9922a"/>
  <!-- Fluke details -->
  <path d="M40 86 Q22 72 18 60" stroke="#a07018" stroke-width="1.5" fill="none"/>
  <path d="M40 86 Q58 72 62 60" stroke="#a07018" stroke-width="1.5" fill="none"/>

  <!-- Chain links -->
  <ellipse cx="40" cy="10" rx="5" ry="3" stroke="#f5ead8" stroke-width="1.5" fill="none" opacity="0.4"/>
  <ellipse cx="40" cy="6" rx="3" ry="5" stroke="#f5ead8" stroke-width="1.5" fill="none" opacity="0.4"/>
  <ellipse cx="40" cy="2" rx="5" ry="3" stroke="#f5ead8" stroke-width="1.5" fill="none" opacity="0.3"/>
</svg>
{{/if}}

{{#if (eq type "waves-hero")}}
{{!-- =====================================================
     ANIMATED HERO OCEAN WAVES
====================================================== --}}
<svg
  class="illustration illustration--waves"
  width="100%"
  viewBox="0 0 1440 180"
  preserveAspectRatio="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  role="presentation"
>
  <defs>
    <linearGradient id="waveDeep" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1a4a6b" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#0a0e1a" stop-opacity="1"/>
    </linearGradient>
    <linearGradient id="waveMid" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1a4a6b" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="#112d45" stop-opacity="0.8"/>
    </linearGradient>
    <!-- Foam sparkle -->
    <radialGradient id="foam" cx="50%" cy="0%" r="50%">
      <stop offset="0%" stop-color="#f5ead8" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#f5ead8" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Back wave -->
  <path
    d="M0 90 C120 70,240 110,360 90 C480 70,600 110,720 90 C840 70,960 110,1080 90 C1200 70,1320 110,1440 90 L1440 180 L0 180Z"
    fill="url(#waveDeep)"
    opacity="0.6"
  >
    <animateTransform attributeName="transform" type="translate" from="0 0" to="-180 0" dur="8s" repeatCount="indefinite"/>
  </path>

  <!-- Mid wave -->
  <path
    d="M0 110 C180 90,360 130,540 110 C720 90,900 130,1080 110 C1260 90,1380 120,1440 110 L1440 180 L0 180Z"
    fill="url(#waveMid)"
    opacity="0.7"
  >
    <animateTransform attributeName="transform" type="translate" from="-180 0" to="0 0" dur="6s" repeatCount="indefinite"/>
  </path>

  <!-- Front wave -->
  <path
    d="M0 130 C240 110,480 150,720 130 C960 110,1200 150,1440 130 L1440 180 L0 180Z"
    fill="#0a0e1a"
    opacity="0.9"
  >
    <animateTransform attributeName="transform" type="translate" from="0 0" to="-120 0" dur="4s" repeatCount="indefinite"/>
  </path>

  <!-- Foam crests -->
  <ellipse cx="180" cy="112" rx="40" ry="6" fill="url(#foam)"/>
  <ellipse cx="540" cy="92" rx="50" ry="6" fill="url(#foam)"/>
  <ellipse cx="900" cy="112" rx="45" ry="6" fill="url(#foam)"/>
  <ellipse cx="1260" cy="92" rx="40" ry="6" fill="url(#foam)"/>

  <!-- Gold shimmer on crests -->
  <path d="M140 115 Q180 108 220 115" stroke="#c9922a" stroke-width="1" fill="none" opacity="0.25"/>
  <path d="M500 95 Q540 88 580 95" stroke="#c9922a" stroke-width="1" fill="none" opacity="0.25"/>
  <path d="M860 115 Q900 108 940 115" stroke="#c9922a" stroke-width="1" fill="none" opacity="0.25"/>
</svg>
{{/if}}

