{{#if (eq type "map-ornament")}}
{{!-- =====================================================
     OLD MAP DECORATIVE ORNAMENT (compass rose)
====================================================== --}}
<svg
  class="illustration illustration--map-ornament"
  width="{{#if width}}{{width}}{{else}}140{{/if}}"
  height="{{#if height}}{{height}}{{else}}140{{/if}}"
  viewBox="0 0 140 140"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Rose des vents décorative"
  role="img"
>
  <!-- Outer circle -->
  <circle cx="70" cy="70" r="66" stroke="#c9922a" stroke-width="1" opacity="0.3" fill="none"/>
