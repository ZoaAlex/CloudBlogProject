{{!< default}}

<main style="max-width:1100px;margin:0 auto;padding:3rem 2rem;background:#0d1b2a;min-height:80vh">
  <div style="margin-bottom:2rem;border-bottom:1px solid rgba(201,146,42,0.2);padding-bottom:1rem">
    <h1 style="font-family:serif;color:#f5d98a;font-size:1.5rem">{{@site.title}}</h1>
    <p style="color:#d9cbb0;font-style:italic">{{@site.description}}</p>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem">
    {{#foreach posts}}
      <a href="{{url}}" style="border:1px solid rgba(201,146,42,0.2);border-radius:4px;padding:1.5rem;background:rgba(13,27,42,0.8);text-decoration:none;display:block;transition:border-color 0.2s">
        {{#if feature_image}}
          <img src="{{feature_image}}" alt="{{title}}" style="width:100%;height:180px;object-fit:cover;border-radius:3px;margin-bottom:1rem">
        {{/if}}
        <h2 style="font-family:serif;color:#f5d98a;font-size:1.1rem;margin-bottom:0.5rem">{{title}}</h2>
        <p style="color:#d9cbb0;font-size:0.85rem;line-height:1.6">{{excerpt words="20"}}</p>
        <p style="color:rgba(201,146,42,0.6);font-size:0.75rem;margin-top:0.75rem">{{date format="D MMM YYYY"}} · {{reading_time}}</p>
      </a>
    {{/foreach}}
  </div>

  {{pagination}}
</main>
