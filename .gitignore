# Données Ghost (ne pas versionner)
content/data/
content/logs/
content/images/
content/adapters/
content/media/
content/files/
content/public/

# Thèmes par défaut Ghost (liens symboliques)
content/themes/casper/
content/themes/source/

# Fichiers de base de données
*.db
*.db-shm
*.db-wal

# Fichiers de log
*.log

# Fichiers de configuration locaux
config.*.json

# Fichier d'environnement
.env

# Garder les thèmes custom et les settings
!content/themes/
!content/themes/grand-line-theme/
!content/themes/mon-theme/
!content/settings/
!content/settings/routes.yaml

# Garder la structure des dossiers data (sans les fichiers)
!content/data/
!content/data/images/
!content/data/images/.gitkeep
!content/data/media/
!content/data/media/.gitkeep
!content/data/files/
!content/data/files/.gitkeep
!content/data/logs/
!content/data/logs/.gitkeep
